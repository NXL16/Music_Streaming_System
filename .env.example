# ========== MySQL ==========
MYSQL_HOST
MYSQL_PORT=3306
MYSQL_USER
MYSQL_PASSWORD
MYSQL_DATABASE

# ========== Redis ==========
REDIS_HOST
REDIS_PORT

# ========== KMS Service ==========
KMS_ENDPOINT=
KMS_SECRET=

# ========== R2 Storage (Cloudflare) ==========
R2_ENDPOINT
R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY
R2_BUCKET_NAME

# ========== FFmpeg ==========
FFMPEG_PATH
TEMP_DIR

# ========== Logging ==========
LOG_LEVEL=debug
LOG_FORMAT=json
SENTRY_DSN

# ========== CORS ==========
CORS_ORIGIN

# ========== Email (Mailhog) ==========
EMAIL_HOST
EMAIL_PORT

# ========== File Upload ==========
MAX_FILE_SIZE=524288000
ALLOWED_MIME_TYPES=audio/mpeg,audio/flac,audio/wav

# ========== Rate Limiting ==========
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ========== Frontend ==========
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_KMS_URL=http://localhost:3000/kms
NEXT_PUBLIC_APP_NAME=Music Streaming
NEXT_PUBLIC_APP_VERSION=1.0.0
