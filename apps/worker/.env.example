# ========== R2 ==========
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_ENDPOINT=
R2_BUCKET=

# ========== Redis ==========
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ========== gRPC ==========
META_GRPC_URL=http://localhost:4410

# ========== Encryption ==========
MASTER_SECRET_KEY=

# ========== Worker Config (optional) ==========
WORKER_MAX_CONCURRENCY=4
WORKER_JOB_MAX_RETRIES=3
WORKER_MAX_SOURCE_SIZE_BYTES=262144000
WORKER_DOWNLOAD_TIMEOUT_SEC=120
WORKER_TRANSCODE_TIMEOUT_SEC=600

# ========== Local mood analysis (Essentia adapter) ==========
# The executable receives the temporary source-file path as its only argument
# and must print JSON: {"version":"essentia-mood-v1","moodTags":["energy"],"scores":{"energy":0.91}}
# It runs after transcode and never prevents a song from becoming READY.
MOOD_ANALYSIS_ENABLED=false
MOOD_ANALYSIS_EXECUTABLE=
# Optional fixed arguments passed before the source audio path.
MOOD_ANALYSIS_ARGUMENTS=
MOOD_ANALYSIS_TIMEOUT_SEC=90
