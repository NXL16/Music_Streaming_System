# ======== PostgreSQL =============
DATABASE_URL

# ========== Redis ==========
REDIS_HOST
REDIS_PORT
REDIS_PASSWORD

# ========== Pending Cleanup ==========
SONG_PENDING_CLEANUP_ENABLED=true
SONG_PENDING_STALE_MINUTES=180
SONG_PENDING_CLEANUP_INTERVAL_SEC=300
SONG_PENDING_CLEANUP_BATCH_SIZE=200

# ========== R2 ==========
R2_ENDPOINT
R2_ACCESS_KEY
R2_SECRET_KEY
R2_BUCKET

# ========== GRPC_URL ==========
ASSET_GRPC_URL=localhost:7979

# ========== GRPC_TOKEN ==========
INTERNAL_GRPC_TOKEN
 
CATALOG_ASSET_SYNC_POLL_INTERVAL_MS=2000
CATALOG_ASSET_SYNC_LOCK_TTL_MS=60000