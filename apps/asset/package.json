{
  "name": "asset",
  "version": "1.0.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "pnpm run prisma:generate && nest build",
    "postbuild": "node -e \"require('fs').cpSync('src/generated/prisma','dist/src/generated/prisma',{recursive:true})\"",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "dev": "nest start --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1093.0",
    "@aws-sdk/s3-request-presigner": "^3.1093.0",
    "@grpc/grpc-js": "^1.14.4",
    "@musical/shared-proto": "workspace:*",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/microservices": "^11.1.28",
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "dotenv": "^17.4.2",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@musical/ts-config": "workspace:*",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "11.1.0",
    "@prisma/config": "^7.9.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "prisma": "^7.9.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.65.0"
  }
}
